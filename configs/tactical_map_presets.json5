// BOAM Tactical Map — display presets
//
// This is the mod default. To customise, copy to:
//   <game_dir>/UserData/BOAM/tactical_map_presets.json5
//
// Three style layers combined into DisplayStyles:
//   Anchors     — screen position
//   MapStyles   — map background tile size (+ optional generation method)
//   EntityStyles — icon size, font size, faction colors, panel chrome
//
// DisplayStyles pair a MapStyle + EntityStyle + Anchor into a preset
// that the user cycles through with the DisplayKey (default L).
{
  "configVersion": 4,

  // ── Anchors ──
  // X: 0.0 = left, 0.5 = center, 1.0 = right
  // Y: 0.0 = top,  0.5 = center, 1.0 = bottom
  "Anchors": [
    { "Key": "top-right",    "X": 1.0, "Y": 0.0 },
    { "Key": "top-left",     "X": 0.0, "Y": 0.0 },
    { "Key": "bottom-right", "X": 1.0, "Y": 1.0 },
    { "Key": "bottom-left",  "X": 0.0, "Y": 1.0 },
    { "Key": "center",       "X": 0.5, "Y": 0.5 }
  ],

  // ── DisplayStyles ──
  // Name          — shown in the overlay header
  // MapStyle      — Key from MapStyles
  // EntityStyle   — Key from EntityStyles
  // Anchor        — Key from Anchors (default "top-right")
  // Opacity       — override global Opacity for this preset (0.1–1.0, optional)
  // MapBrightness — override global MapBrightness for this preset (0.1–4.0, optional)
  "DisplayStyles": [
    { "Name": "1080 M",      "MapStyle": "captured",      "EntityStyle": "native",         "Anchor": "bottom-right", "Opacity": 0.8, "MapBrightness": 4.0 },
    { "Name": "1080 Clean",  "MapStyle": "captured",      "EntityStyle": "native-nolabel", "Anchor": "bottom-right", "Opacity": 0.8, "MapBrightness": 4.0 },
    { "Name": "1080 L",      "MapStyle": "captured-l",    "EntityStyle": "native-l",       "Anchor": "center",       "Opacity": 0.8, "MapBrightness": 4.0 },
    { "Name": "4K M",        "MapStyle": "captured-4k",   "EntityStyle": "native-4k",      "Anchor": "bottom-right", "Opacity": 0.8, "MapBrightness": 4.0 },
    { "Name": "4K L",        "MapStyle": "captured-4k-l", "EntityStyle": "native-4k-l",    "Anchor": "center",       "Opacity": 0.8, "MapBrightness": 4.0 },
    { "Name": "1080 L",      "MapStyle": "captured-4k-l", "EntityStyle": "native-4k-l-nolabel",       "Anchor": "center", "Opacity": 0.8, "MapBrightness": 4.0 }
  ],

  // ── MapStyles ──
  // Key       — reference name used by DisplayStyles
  // TileSize  — pixels per tile on screen (default 12)
  // TileFolder — compose from tile PNGs in Mods/BOAM/<folder>/ (optional)
  // MapColors  — generate from flat hex colors (optional):
  //     MinHeight, MaxHeight    — height gradient (#RRGGBB or #RRGGBBAA)
  //     BlockedMin, BlockedMax  — blocked terrain gradient
  //     Roads, Vegetation, Structures — overlay colors (use alpha for blending)
  // (neither TileFolder nor MapColors) — use the captured game texture (mapbg.png)
  "MapStyles": [
    { "Key": "captured",      "TileSize": 18 },
    { "Key": "captured-l",    "TileSize": 24 },
    { "Key": "captured-4k",   "TileSize": 36 },
    { "Key": "captured-4k-l", "TileSize": 48 }
  ],

  // ── EntityStyles ──
  // Key           — reference name used by DisplayStyles
  // IconSize      — icon size in pixels (default 10)
  // FontSize      — unit label font size in pixels (default 9, 0 = no labels)
  // Background    — panel background color #RRGGBBAA (default "#120803E6")
  // HeaderText    — header text color (default "#F7AD66")
  // FactionColors — per-faction label/dot colors:
  //     Keys: Player, PlayerAI, Civilian, AlliedLocalForces,
  //           EnemyLocalForces, Pirates, Wildlife, Constructs,
  //           RogueArmy, Default
  //     Values: hex color strings (#RRGGBB or #RRGGBBAA)
  "EntityStyles": [
    {
      "Key": "native",
      "IconSize": 18,
      "FontSize": 12,
      "Background": "#120803E6",
      "HeaderText": "#F7AD66",
      "FactionColors": {
        "Player": "#4DC99E", "PlayerAI": "#4DC99E", "Civilian": "#F7AD40",
        "AlliedLocalForces": "#4DC99E", "EnemyLocalForces": "#FF4242",
        "Pirates": "#FF4242", "Wildlife": "#F705FF", "Constructs": "#BA9478",
        "RogueArmy": "#FF4242", "Default": "#BA9478"
      }
    },
    {
      "Key": "native-nolabel",
      "IconSize": 18,
      "FontSize": 0,
      "Background": "#120803E6",
      "HeaderText": "#F7AD66",
      "FactionColors": {
        "Player": "#4DC99E", "PlayerAI": "#4DC99E", "Civilian": "#F7AD40",
        "AlliedLocalForces": "#4DC99E", "EnemyLocalForces": "#FF4242",
        "Pirates": "#FF4242", "Wildlife": "#F705FF", "Constructs": "#BA9478",
        "RogueArmy": "#FF4242", "Default": "#BA9478"
      }
    },
    {
      "Key": "native-l",
      "IconSize": 24,
      "FontSize": 16,
      "Background": "#120803E6",
      "HeaderText": "#F7AD66",
      "FactionColors": {
        "Player": "#4DC99E", "PlayerAI": "#4DC99E", "Civilian": "#F7AD40",
        "AlliedLocalForces": "#4DC99E", "EnemyLocalForces": "#FF4242",
        "Pirates": "#FF4242", "Wildlife": "#F705FF", "Constructs": "#BA9478",
        "RogueArmy": "#FF4242", "Default": "#BA9478"
      }
    },
    {
      "Key": "native-4k",
      "IconSize": 48,
      "FontSize": 22,
      "Background": "#120803E6",
      "HeaderText": "#F7AD66",
      "FactionColors": {
        "Player": "#4DC99E", "PlayerAI": "#4DC99E", "Civilian": "#F7AD40",
        "AlliedLocalForces": "#4DC99E", "EnemyLocalForces": "#FF4242",
        "Pirates": "#FF4242", "Wildlife": "#F705FF", "Constructs": "#BA9478",
        "RogueArmy": "#FF4242", "Default": "#BA9478"
      }
    },
    {
      "Key": "native-4k-l",
      "IconSize": 48,
      "FontSize": 28,
      "Background": "#120803E6",
      "HeaderText": "#F7AD66",
      "FactionColors": {
        "Player": "#4DC99E", "PlayerAI": "#4DC99E", "Civilian": "#F7AD40",
        "AlliedLocalForces": "#4DC99E", "EnemyLocalForces": "#FF4242",
        "Pirates": "#FF4242", "Wildlife": "#F705FF", "Constructs": "#BA9478",
        "RogueArmy": "#FF4242", "Default": "#BA9478"
      }
    },
    {
      "Key": "native-4k-l-nolabel",
      "IconSize": 48,
      "FontSize": 0,
      "Background": "#120803E6",
      "HeaderText": "#F7AD66",
      "FactionColors": {
        "Player": "#4DC99E", "PlayerAI": "#4DC99E", "Civilian": "#F7AD40",
        "AlliedLocalForces": "#4DC99E", "EnemyLocalForces": "#FF4242",
        "Pirates": "#FF4242", "Wildlife": "#F705FF", "Constructs": "#BA9478",
        "RogueArmy": "#FF4242", "Default": "#BA9478"
      }
    }
  ]
}
