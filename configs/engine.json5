// BOAM Tactical Engine — main configuration
//
// This is the mod default. To customise, copy to:
//   <game_dir>/UserData/BOAM/configs/engine.json5
{
  "configVersion": 2,

  // ── Network ──
  "port": 7660,                // tactical engine HTTP port
  "bridge_port": 7655,         // game bridge port (C# side)
  "command_port": 7661,        // command server port

  // ── Features ──
  // Toggle individual features on/off. Only the minimap is enabled by default.
  // The minimap toggle is in tactical_map.json5 ("Enabled": true/false).
  "heatmaps": false,           // collect render job data (tile scores, decisions) for offline heatmap generation
  "action_logging": false,     // log player actions + AI decisions to round_log.jsonl
  "ai_logging": false,         // log AI decisions (requires action_logging; enables determinism watchdog)
  "criterion_logging": false,  // log per-tile criterion breakdown (utility, safety, distance) to criterion_scores.jsonl

  // ── Rendering ──
  // Controls heatmap image rendering (offline render jobs).
  // Colors are [R, G, B, A] arrays (0-255).
  "rendering": {
    "minTilePixels": 64,       // minimum pixels per tile (controls upscaling for readability)
    "gamma": 0.35,             // gamma correction for map background (< 1.0 brightens shadows)
    "fontFamily": "DejaVu Sans Mono",  // font for score text on heatmaps
    "scoreFontScale": 0.32,    // score text size relative to tile size
    "labelFontScale": 0.33,    // unit label size relative to tile size

    // ── Border Styles ──
    // Each border: margin (px inset), thickness (px), color [R,G,B,A]
    "borders": {
      "actor":    { "margin": 2, "thickness": 3, "color": [255, 50, 50, 220] },   // red: analyzed actor
      "bestTile": { "margin": 1, "thickness": 2, "color": [50, 255, 50, 230] },   // green: highest-scored tile
      "moveDest": { "margin": 3, "thickness": 2, "color": [60, 140, 255, 230] },  // blue: move destination
      "vision":   [255, 220, 50, 200]                                              // yellow: vision range border
    },

    // ── Faction Colors ──
    // Keyed by faction index. Used for unit icons/labels on heatmaps.
    // 0=Neutral, 1=Player, 2=PlayerAI, 3=Civilian, 4=Allied,
    // 5=EnemyLocal, 6=Pirates, 7=Wildlife, 8=Constructs, 9=RogueArmy
    "factionColors": {
      "0":  [128, 128, 128, 200],
      "1":  [60, 140, 255, 200],
      "2":  [80, 160, 255, 200],
      "3":  [200, 200, 100, 200],
      "4":  [100, 200, 100, 200],
      "5":  [200, 100, 50, 200],
      "6":  [180, 50, 180, 200],
      "7":  [255, 60, 60, 200],
      "8":  [160, 160, 160, 200],
      "9":  [200, 50, 50, 200]
    }
  }
}
