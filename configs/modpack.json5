// BOAM Modpack — in-game mod configuration
//
// This is the mod default. To customise, copy to:
//   <game_dir>/UserData/BOAM/configs/modpack.json5
{
  "configVersion": 1,

  // ── AI Tweaks ──
  // Experimental features that modify AI behavior at runtime.
  // These are NOT read-only observations — they change how the AI plays.

  // Strip opponents from AI faction's m_Opponents that no faction member can see via LOS.
  // Prevents AI from "knowing" about concealed units it hasn't detected.
  // Default: false (observation-only mode, no AI modification)
  "opponent_filter": false
}
