// BOAM Behaviour Presets — AI movement modifier tuning
//
// This is the mod default. To customise, copy to:
//   <game_dir>/UserData/BOAM/configs/behaviour.json5
//
// Each behaviour (roaming, reposition, pack) has named presets.
// The "active" block selects which preset each behaviour uses.
// All values are optional — missing fields use the built-in defaults.
//
// Score scaling: modifiers scale relative to the game's own tile evaluation scores.
// "fraction" controls the multiplier: modifier = max(default, gameMaxScore * fraction).
// The default value is the floor — game scaling only kicks in when it produces higher values.
{
  "configVersion": 5,

  // ── Data Events ──
  // C# data gathering that is only performed when listed here.
  // Remove an entry to disable it.
  //
  // Core:
  //   on-turn-start        — faction state sent to engine at AI turn start
  //   on-turn-end          — actor status sent to engine at turn end
  //   movement-finished    — position update sent to engine after movement
  //   actor-changed        — active actor notification sent to engine
  //   scene-change         — scene transition notification
  //   battle-start         — battle session init
  //   battle-end           — battle session cleanup
  //   tactical-ready       — dramatis personae + init sent to engine
  //   preview-ready        — map capture signal
  //
  // Behaviour:
  //   contact-state        — per-actor detection state (roaming, reposition)
  //   movement-budget      — AP/skill/movement cost (roaming, reposition)
  //   objective-detection  — mission objective targets (guard-vip)
  //   tile-modifiers       — tile score modifier pipeline (any behaviour node)
  //   opponent-tracking    — faction opponent list at turn-start (reposition)
  //
  // Observation:
  //   tile-scores          — tile evaluation data sent to engine (scoring, heatmaps, criterion logging)
  //   decision-capture     — AI behaviour decisions sent to engine (logging, heatmaps)
  //   minimap-units        — unit positions from tile evaluation
  //
  // Logging:
  //   action-logging       — player and AI action events
  //   combat-logging       — damage / element hit events
  "dataEvents": [
    "on-turn-start",
    "on-turn-end",
    "movement-finished",
    "actor-changed",
    "scene-change",
    "battle-start",
    "battle-end",
    "tactical-ready",
    "preview-ready",
    //Optional
    "contact-state",
    "movement-budget",
    "tile-modifiers",
    "opponent-tracking",
    "tile-scores",
    "minimap-units"
  ],

  // Events listed here are recognized but inactive by default.
  // Move an entry to "dataEvents" to enable it.
  "inactiveDataEvents": [
    "objective-detection",
    "decision-capture",
    "action-logging",
    "combat-logging"
  ],

  // ── Hook Chains ──
  // Define which behaviour nodes run on each hook point, and in what order.
  // Node names must match registered catalogue entries.
  // Remove a node from the list to disable it. Reorder to change execution priority.
  "hooks": {
    "OnTacticalReady": ["roaming-init", "pack-init"],
    "OnTurnEnd": ["roaming-behaviour", "reposition-behaviour", "pack-behaviour"]
  },

  // ── Active Presets ──
  // Select which preset each behaviour uses by name.
  "active": {
    "roaming": "default",
    "reposition": "default",
    "pack": "default",
    "guard-vip": "default"
  },

  // ── Roaming ── (targets Utility score)
  // Encourages idle units to explore outward. Disabled near engagement.
  //
  // baseUtility      — default modifier strength (floor for game score scaling)
  // utilityFraction  — modifier as fraction of game max score (1.0 = match game scores)
  // engagementRadius — tiles; suppress roaming when any same-faction engaged ally is within this range
  "roaming": {
    "default": {
      "baseUtility": 10,
      "utilityFraction": 1.0,
      "engagementRadius": 20
    }
  },

  // ── Reposition ── (targets UtilityByAttacks score)
  // Moves units toward their ideal attack range from the closest known opponent.
  // Only active near engagement. Melee units get stronger pull (scaled by 1/idealRange).
  //
  // maxUtilityByAttacks — default modifier strength for melee (idealRange=1); ranged = value/idealRange
  // utilityByAttacksFraction — modifier as fraction of game max score
  // approachBias       — 0.0–1.0; favor near-side tiles over far-side with equal improvement
  //                      0 = pure ideal-range positioning, 1 = full proximity weighting
  "reposition": {
    "default": {
      "maxUtilityByAttacks": 300,
      "utilityByAttacksFraction": 1.0,
      "approachBias": 0.5
    }
  },

  // ── Pack ── (targets Safety score)
  // Pulls units toward allies. Directional scoring: tiles that improve pack density score higher.
  // Engaged allies (inRange && inContact) get extra weight. No crowd penalty near engaged allies.
  //
  // radius          — influence range per ally (tiles)
  // peak            — ideal density; above this, crowd penalty applies (unless engaged ally nearby)
  // baseSafety      — default safety per density unit below peak (floor for game score scaling)
  // safetyFraction  — baseSafety as fraction of game max score
  // crowdPenalty    — penalty per density unit above peak (suppressed near engaged allies)
  // anchoredWeight  — influence multiplier for allies that already acted this round
  // unactedWeight   — influence multiplier for allies that haven't acted yet
  // contactBonus    — extra influence weight for engaged allies (inRange && inContact)
  // initMultiplier  — boost factor for pack scores at tactical-ready (round 1 pack formation)
  "pack": {
    "default": {
      "radius": 20,
      "peak": 4.0,
      "baseSafety": 560,
      "safetyFraction": 1.2,
      "crowdPenalty": 120,
      "anchoredWeight": 1.0,
      "unactedWeight": 0.3,
      "contactBonus": 1.5,
      "initMultiplier": 3.0
    }
  },

  // ── Guard VIP ── (targets Safety score) [WIP — not in hook chain by default]
  // Draws same-faction units toward mission objective targets (VIPs / ELIMINATE markers).
  // Only active when the mission has objective actors. Non-objective units get safety
  // modifiers for tiles closer to objective allies.
  // To enable, add "guard-vip-behaviour" to the OnTurnEnd hook chain above.
  //
  // radius         — influence range from each objective actor (tiles)
  // baseSafety     — default modifier strength (floor for game score scaling)
  // safetyFraction — modifier as fraction of game max score
  // weight         — influence multiplier per objective actor
  "guard-vip": {
    "default": {
      "radius": 15,
      "baseSafety": 400,
      "safetyFraction": 1.5,
      "weight": 2.0
    }
  }
}
