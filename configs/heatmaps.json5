// BOAM Heatmap Rendering — rendering settings for offline heatmap generation
//
// This is the mod default. To customise, copy to:
//   <game_dir>/UserData/BOAM/configs/heatmaps.json5
//
// Colors are [R, G, B, A] arrays (0-255).
{
  "configVersion": 1,

  "minTilePixels": 64,
  "gamma": 0.35,
  "fontFamily": "DejaVu Sans Mono",
  "scoreFontScale": 0.32,
  "labelFontScale": 0.33,

  "borders": {
    "actor":    { "margin": 2, "thickness": 3, "color": [255, 50, 50, 220] },
    "bestTile": { "margin": 1, "thickness": 2, "color": [50, 255, 50, 230] },
    "moveDest": { "margin": 3, "thickness": 2, "color": [60, 140, 255, 230] },
    "vision":   [255, 220, 50, 200]
  },

  // Keyed by faction index.
  // 0=Neutral, 1=Player, 2=PlayerAI, 3=Civilian, 4=Allied,
  // 5=EnemyLocal, 6=Pirates, 7=Wildlife, 8=Constructs, 9=RogueArmy
  "factionColors": {
    "0":  [128, 128, 128, 200],
    "1":  [60, 140, 255, 200],
    "2":  [80, 160, 255, 200],
    "3":  [200, 200, 100, 200],
    "4":  [100, 200, 100, 200],
    "5":  [200, 100, 50, 200],
    "6":  [180, 50, 180, 200],
    "7":  [255, 60, 60, 200],
    "8":  [160, 160, 160, 200],
    "9":  [200, 50, 50, 200]
  }
}
